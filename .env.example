# ============================================================================
# VF-AD-ROUTER-CORE ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual credentials

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=production
PORT=3000
CHECKOUT_URL=https://example.com/beats
WEBHOOK_URL=https://your-domain.com
ADMIN_JWT_SECRET=your-super-secret-admin-jwt-key-change-me-in-production

# ============================================================================
# YOUTUBE API CREDENTIALS
# ============================================================================
YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token

# ============================================================================
# TIKTOK API CREDENTIALS
# ============================================================================
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_BUSINESS_ACCOUNT_ID=your-tiktok-business-account-id

# ============================================================================
# PINTEREST API CREDENTIALS
# ============================================================================
PINTEREST_ACCESS_TOKEN=your-pinterest-access-token
PINTEREST_BUSINESS_ACCOUNT_ID=your-pinterest-business-account-id

# ============================================================================
# TUMBLR API CREDENTIALS
# ============================================================================
TUMBLR_CONSUMER_KEY=your-tumblr-consumer-key
TUMBLR_CONSUMER_SECRET=your-tumblr-consumer-secret
TUMBLR_ACCESS_TOKEN=your-tumblr-access-token
TUMBLR_ACCESS_TOKEN_SECRET=your-tumblr-access-token-secret
TUMBLR_BLOG_NAME=your-blog-name.tumblr.com

# ============================================================================
# META (FACEBOOK/INSTAGRAM) API CREDENTIALS
# ============================================================================
META_PAGE_ACCESS_TOKEN=your-meta-page-access-token
META_BUSINESS_ACCOUNT_ID=your-meta-business-account-id
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=your-meta-instagram-business-account-id
META_WEBHOOK_VERIFY_TOKEN=your-meta-webhook-verify-token

# ============================================================================
# TWITTER/X API CREDENTIALS
# ============================================================================
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret

# ============================================================================
# REDDIT API CREDENTIALS
# ============================================================================
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password
REDDIT_USER_AGENT=VFAdRouter/1.0 (by your-reddit-username)

# ============================================================================
# AUDIO ANALYSIS CONFIGURATION
# ============================================================================
# For automatic BPM and Key detection when not available in metadata
ENABLE_AUDIO_ANALYSIS=true
AUDIO_ANALYSIS_TIMEOUT=30000
MAX_AUDIO_SAMPLE_DURATION=30

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
MAX_FILE_SIZE=500000000
MAX_CONCURRENT_UPLOADS=5

# ============================================================================
# STREAM CONFIGURATION
# ============================================================================
STREAM_TIMEOUT=60000
STREAM_BUFFER_SIZE=65536
MAX_REDIRECTS=5

# ============================================================================
# DISTRIBUTION CONFIGURATION
# ============================================================================
ENABLE_YOUTUBE_DISTRIBUTION=true
ENABLE_TIKTOK_DISTRIBUTION=true
ENABLE_TWITTER_DISTRIBUTION=true
ENABLE_REDDIT_DISTRIBUTION=true
ENABLE_PINTEREST_DISTRIBUTION=true
ENABLE_TUMBLR_DISTRIBUTION=true
ENABLE_META_DISTRIBUTION=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true
LOG_ROTATION_MAX_SIZE=10m
LOG_RETENTION_DAYS=30

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
ENABLE_REDIS_CACHE=false
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# ERROR HANDLING & RECOVERY
# ============================================================================
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=5000
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_MS=60000

# ============================================================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================================================
# For advanced audio analysis (e.g., Spotify API for metadata)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# For video watermarking/branding
ENABLE_WATERMARK=true
WATERMARK_TEXT=Your Beat Store

# For analytics tracking
ANALYTICS_ENABLED=true
ANALYTICS_WEBHOOK_URL=

# ============================================================================
# SECURITY
# ============================================================================
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,https://example.com
API_KEY_HEADER_NAME=X-API-Key
REQUIRE_API_KEY=false
